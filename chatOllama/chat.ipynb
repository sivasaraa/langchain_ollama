    "from langchain_ollama import ChatOllama\n",
    "\n",
    "llm = ChatOllama(model='llama3.2', temperature=0.7)\n",
    "\n",
    "message = [(\"system\", \"explain the topic in 2 sentence in english\"),(\"human\",\"AI\")]\n",
    "\n",
    "response = llm.invoke(message)\n",
    "print(response)"
